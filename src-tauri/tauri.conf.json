{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quantum Leap",
  "version": "1.2.0",
  "identifier": "com.anti2077.quantumleap",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Quantum Leap",
        "width": 1280,
        "height": 825,
        "minWidth": 760,
        "minHeight": 700,
        "resizable": true,
        "transparent": false,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "backgroundColor": "#f4f7fb"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright © 2026 Anti2077",
    "license": "GPL-3.0-only",
    "resources": {
      "../LICENSE": "LICENSE"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "SSH-powered iperf3 network testing for macOS",
    "longDescription": "Quantum Leap manages remote iperf3 sessions over SSH and visualizes live TCP and UDP network performance on macOS.",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-",
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": {
          "width": 880,
          "height": 520
        },
        "appPosition": {
          "x": 220,
          "y": 260
        },
        "applicationFolderPosition": {
          "x": 660,
          "y": 260
        }
      }
    }
  }
}

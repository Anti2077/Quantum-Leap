{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "title": "Quantum Leap",
        "width": 1280,
        "height": 825,
        "minWidth": 760,
        "minHeight": 700,
        "resizable": true,
        "transparent": false,
        "decorations": true,
        "backgroundColor": "#f4f7fb"
      }
    ]
  },
  "bundle": {
    "targets": ["appimage", "deb"],
    "externalBin": ["binaries/iperf3"],
    "resources": {
      "binaries/licenses/*": "third-party/"
    }
  }
}
